# ---------------------------------------------------------------------------
# Franklink-iMessage — environment template
# Copy this file to `.env` and fill in the values. Never commit `.env`.
# ---------------------------------------------------------------------------

# ── Azure OpenAI ──────────────────────────────────────────────────────────
# Get these from https://portal.azure.com → your Azure OpenAI resource → Keys & Endpoint
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5-mini
AZURE_OPENAI_REASONING_DEPLOYMENT_NAME=gpt-5-mini

# ── Supabase (primary database) ───────────────────────────────────────────
# Get from your Supabase project → Settings → API
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_KEY=                 # anon / public key
SUPABASE_SERVICE_KEY=         # service_role key — server only, never ship to clients
POSTGRES_CONNECTION_STRING=postgresql://postgres:<password>@db.<your-project>.supabase.co:5432/postgres

# ── Supabase (resources catalog) ──────────────────────────────────────────
# Optional — separate Supabase project used for books / videos / courses.
RESOURCES_SUPABASE_URL=
RESOURCES_SUPABASE_KEY=
RESOURCES_SUPABASE_SERVICE_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────
# Used for background jobs, idempotency, and caching.
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_IDEMPOTENCY_TTL=86400
REDIS_CACHE_TTL=300
REDIS_RATE_LIMIT_WINDOW=60

# ── FastAPI ───────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
DEBUG=True

# ── Photon (iMessage bridge) ──────────────────────────────────────────────
# Photon is the service that proxies iMessage webhooks.
PHOTON_SERVER_URL=
PHOTON_DEFAULT_NUMBER=
PHOTON_ENABLE_LISTENER=true
PHOTON_API_KEY=
WEBHOOK_SECRET=
WEBHOOK_ENDPOINT=/webhook/photon

# ── Zep (long-term memory) ────────────────────────────────────────────────
# Get your API key from https://app.getzep.com/ or run self-hosted.
ZEP_API_KEY=
ZEP_BASE_URL=https://api.getzep.com
ZEP_ENABLED=true

# ── Composio (Gmail read-only context) ────────────────────────────────────
# Get from https://app.composio.dev/
COMPOSIO_API_KEY=
COMPOSIO_BASE_URL=
COMPOSIO_ENTITY_PREFIX=franklink
COMPOSIO_GMAIL_PROVIDER=gmail
COMPOSIO_AUTH_CONFIG_ID=
COMPOSIO_GMAIL_TOOLKIT_VERSION=

# ── Google OAuth ──────────────────────────────────────────────────────────
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_PROJECT_ID=

# URLs displayed to Google during OAuth consent.
LOGIN_PAGE_URL=
PRIVACY_POLICY_URL=
TERMS_OF_SERVICE_URL=
DATA_DELETION_URL=

# ── Stripe (optional; payment helpers are retained but not active in graphs) ─
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:8000/payment/success
STRIPE_CANCEL_URL=http://localhost:8000/payment/cancel

# ── LinkedIn scraping providers (optional) ────────────────────────────────
BRIGHTDATA_API_KEY=
SCRAPINGDOG_API_KEY=
SCRAPINGDOG_TIMEOUT=30
SCRAPINGDOG_RETRY_ATTEMPTS=2
SCRAPINGDOG_USE_PREMIUM=true

# ── Reddit (optional; used by some recommendation heuristics) ─────────────
REDDIT_CLIENT_ID=
REDDIT_SECRET_KEY=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# ── Observability / limits ────────────────────────────────────────────────
SENTRY_DSN=
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
